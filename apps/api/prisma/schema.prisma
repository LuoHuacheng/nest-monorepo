generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "commonjs"
}

datasource db {
  provider = "postgresql"
}

// ==================== 系统基础表 ====================

model SysUser {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  name      String
  avatar    String?
  phone     String?
  email     String?
  status    Int      @default(1) // 1=启用 0=禁用
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  userRoles SysUserRole[]
  logs      SysLog[]
  orders    Order[]

  @@map("sys_user")
}

model SysRole {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  description String?
  status      Int      @default(1)
  createdAt   DateTime @default(now()) @map("created_at")

  userRoles       SysUserRole[]
  rolePermissions SysRolePermission[]

  @@map("sys_role")
}

model SysUserRole {
  userId String @map("user_id")
  roleId String @map("role_id")

  user SysUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  role SysRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("sys_user_role")
}

model SysPermission {
  id       String  @id @default(cuid())
  name     String
  code     String  @unique
  type     String  @default("button") // button / api
  parentId String? @map("parent_id")

  rolePermissions SysRolePermission[]

  @@map("sys_permission")
}

model SysRolePermission {
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role       SysRole       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission SysPermission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("sys_role_permission")
}

model SysMenu {
  id             String   @id @default(cuid())
  name           String
  path           String?
  icon           String?
  parentId       String?  @map("parent_id")
  sort           Int      @default(0)
  type           String   @default("menu") // dir / menu / button
  permissionCode String?  @map("permission_code")
  status         Int      @default(1)
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("sys_menu")
}

model SysDict {
  id          String  @id @default(cuid())
  name        String
  code        String  @unique
  description String?
  status      Int     @default(1)

  items SysDictItem[]

  @@map("sys_dict")
}

model SysDictItem {
  id     String @id @default(cuid())
  dictId String @map("dict_id")
  label  String
  value  String
  sort   Int    @default(0)
  status Int    @default(1)

  dict SysDict @relation(fields: [dictId], references: [id], onDelete: Cascade)

  @@map("sys_dict_item")
}

model SysLog {
  id             String   @id @default(cuid())
  userId         String?  @map("user_id")
  module         String?
  action         String?
  method         String?
  path           String?
  ip             String?
  requestBody    String?  @map("request_body")
  responseStatus Int?     @map("response_status")
  createdAt      DateTime @default(now()) @map("created_at")

  user SysUser? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("sys_log")
}

// ==================== 业务表 ====================

model Event {
  id                    String    @id @default(cuid())
  name                  String
  category              String?
  publishStatus         String    @default("draft") @map("publish_status") // draft / published / offline
  groupDrawCompleted    Boolean   @default(false) @map("group_draw_completed")
  adminConfirmed        Boolean   @default(false) @map("admin_confirmed")
  startDate             DateTime  @map("start_date")
  endDate               DateTime  @map("end_date")
  registrationStartDate DateTime? @map("registration_start_date")
  registrationEndDate   DateTime? @map("registration_end_date")
  province              String?
  city                  String?
  address               String?
  location              String
  tags                  String?   @default("")
  packetPickupTime      DateTime? @map("packet_pickup_time")
  packetPickupLocation  String?   @map("packet_pickup_location")
  coverImages           Json      @default("[]") @map("cover_images")
  isHot                 Boolean   @default(false) @map("is_hot")
  attributes            Json      @default("[]")
  description           String?
  remark                String?
  competitionRules      String?   @map("competition_rules")
  entryStatement        String?   @map("entry_statement")
  raceRoute             String?   @map("race_route")
  registrationNotice    String?   @map("registration_notice")
  pickupNotice          String?   @map("pickup_notice")
  maxParticipants       Int       @map("max_participants")
  currentParticipants   Int       @default(0) @map("current_participants")
  organizerId           String?   @map("organizer_id")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  registrationGroups RegistrationGroup[]
  inviteCodes        EventInviteCode[]
  shuttleBuses      EventShuttleBus[]
  results           EventResult[]
  orders            Order[]

  @@map("event")
}

model RegistrationGroup {
  id              String   @id @default(cuid())
  eventId         String   @map("event_id")
  name            String
  groupType       String   @default("个人组") @map("group_type")
  specName        String   @default("") @map("spec_name")
  specDescription String?  @map("spec_description")
  genderLimit     String   @default("不限") @map("gender_limit")
  minAge          Int?     @map("min_age")
  maxAge          Int?     @map("max_age")
  price           Decimal  @db.Decimal(10, 2)
  quota           Int
  soldCount       Int      @default(0) @map("sold_count")
  status          Int      @default(1)
  sort            Int      @default(0)
  createdAt       DateTime @default(now()) @map("created_at")

  event       Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  orders      Order[]
  inviteCodes EventInviteCode[]

  @@map("registration_group")
}

model RegistrationCard {
  id                    String   @id @default(cuid())
  name                  String
  relationship          String   @default("本人")
  idNumber              String   @map("id_number")
  gender                String
  birthDate             DateTime @map("birth_date")
  bloodType             String?  @map("blood_type")
  clothingSize          String?  @map("clothing_size")
  phone                 String
  province              String?
  city                  String?
  permanentAddress      String?  @map("permanent_address")
  detailedAddress       String?  @map("detailed_address")
  emergencyContactName  String   @map("emergency_contact_name")
  emergencyContactPhone String   @map("emergency_contact_phone")
  status                Int      @default(1)
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@map("registration_card")
}

model EventInviteCode {
  id                  String    @id @default(cuid())
  eventId             String    @map("event_id")
  registrationGroupId String?   @map("registration_group_id")
  desc                String?
  code                String    @unique
  discount            Int       @default(100)
  maxUses             Int       @map("max_uses")
  usedCount           Int       @default(0) @map("used_count")
  status              Int       @default(1)
  expiresAt           DateTime? @map("expires_at")
  createdAt           DateTime  @default(now()) @map("created_at")

  event             Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  registrationGroup RegistrationGroup? @relation(fields: [registrationGroupId], references: [id], onDelete: SetNull)
  orders            Order[]

  @@map("event_invite_code")
}

model EventShuttleBus {
  id            String   @id @default(cuid())
  eventId       String   @map("event_id")
  route         String
  departureTime DateTime @map("departure_time")
  capacity      Int
  status        Int      @default(1)
  createdAt     DateTime @default(now()) @map("created_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("event_shuttle_bus")
}

model EventResult {
  id         String   @id @default(cuid())
  eventId    String   @map("event_id")
  userId     String?  @map("user_id")
  bibNumber  String   @map("bib_number")
  finishTime String   @map("finish_time")
  rank       Int?
  status     Int      @default(1)
  createdAt  DateTime @default(now()) @map("created_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("event_result")
}

model Order {
  id                 String    @id @default(cuid())
  orderNo            String    @unique @map("order_no")
  type               String    @default("event") // event / online
  eventId            String?   @map("event_id")
  userId             String?   @map("user_id")
  registrationCardId String?   @map("registration_card_id")
  inviteCodeId       String?   @map("invite_code_id")
  amount             Decimal   @db.Decimal(10, 2)
  status             String    @default("pending") // pending / paid / refunded / cancelled
  isDrawn            Boolean   @default(false) @map("is_drawn")
  paidAt             DateTime? @map("paid_at")
  refundedAt         DateTime? @map("refunded_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  event            Event?                 @relation(fields: [eventId], references: [id], onDelete: SetNull)
  registrationGroup RegistrationGroup? @relation(fields: [registrationCardId], references: [id], onDelete: SetNull)
  user             SysUser?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  inviteCode       EventInviteCode?       @relation(fields: [inviteCodeId], references: [id], onDelete: SetNull)

  @@map("order")
}

model Organizer {
  id            String    @id @default(cuid())
  loginAccount  String?   @unique @map("login_account")
  name          String
  contact       String?
  phone         String?
  backupContact String?   @map("backup_contact")
  backupPhone   String?   @map("backup_phone")
  certificateNo String?   @map("certificate_no")
  eventDate     DateTime? @map("event_date")
  province      String?
  city          String?
  address       String?
  eventScale    Int?      @map("event_scale")
  eventItems    Json      @default("[]") @map("event_items")
  operator      String?
  email         String?
  remark        String?
  password      String?
  status        Int       @default(1)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@map("organizer")
}

model AthleticCenter {
  id           String   @id @default(cuid())
  name         String
  contact      String?
  phone        String?
  address      String?
  loginAccount String   @unique @map("login_account")
  password     String
  remark       String?
  status       Int      @default(1)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("athletic_center")
}

model Pacer {
  id                   String    @id @default(cuid())
  pacerNo              String?   @unique @map("pacer_no")
  name                 String
  phone                String?
  idCard               String?   @map("id_card")
  avatar               String?
  paceSegments         Json      @default("[]") @map("pace_segments")
  targetTime           String?   @map("target_time")
  clothingSize         String?   @map("clothing_size")
  validFrom            DateTime? @map("valid_from")
  validTo              DateTime? @map("valid_to")
  healthReportUrl      String?   @map("health_report_url")
  ecgImageUrl          String?   @map("ecg_image_url")
  marathonCertificates Json      @default("[]") @map("marathon_certificates")
  pacePlanImageUrl     String?   @map("pace_plan_image_url")
  status               String    @default("pending") // pending / approved / suspended / revoked
  approvedAt           DateTime? @map("approved_at")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  tests  PacerTest[]
  events PacerEvent[]

  @@map("pacer")
}

model PacerTest {
  id         String   @id @default(cuid())
  pacerId    String   @map("pacer_id")
  testDate   DateTime @map("test_date")
  location   String?
  finishTime String   @map("finish_time")
  videoUrl   String?  @map("video_url")
  status     Int      @default(1)
  createdAt  DateTime @default(now()) @map("created_at")

  pacer Pacer @relation(fields: [pacerId], references: [id], onDelete: Cascade)

  @@map("pacer_test")
}

model PacerEvent {
  id         String   @id @default(cuid())
  pacerId    String   @map("pacer_id")
  eventId    String   @map("event_id")
  targetTime String?  @map("target_time")
  status     String   @default("assigned") // assigned / withdrawn / completed
  assignedAt DateTime @default(now()) @map("assigned_at")
  createdAt  DateTime @default(now()) @map("created_at")

  pacer Pacer @relation(fields: [pacerId], references: [id], onDelete: Cascade)

  @@map("pacer_event")
}

model Notification {
  id         String    @id @default(cuid())
  title      String
  content    String
  type       String?
  targetType String    @default("all") @map("target_type") // all / user
  targetId   String?   @map("target_id")
  status     String    @default("pending") // sent / pending
  sentAt     DateTime? @map("sent_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@map("notification")
}

model ClientConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("client_config")
}

model File {
  id           String   @id @default(cuid())
  originalName String   @map("original_name")
  filename     String
  path         String
  mimeType     String   @map("mime_type")
  size         Int
  uploaderId   String?  @map("uploader_id")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("file")
}
