{
  "name": "match",
  "private": true,
  "scripts": {
    "dev:admin": "pnpm --filter admin dev",
    "dev:api": "pnpm --filter api start:dev",
    "dev:miniapp": "pnpm --filter miniapp dev:weapp",
    "build:admin": "pnpm --filter admin build",
    "build:api": "pnpm --filter api build",
    "build:miniapp": "pnpm --filter miniapp build:weapp",
    "lint": "pnpm -r lint",
    "lint:check": "pnpm -r lint:check",
    "format": "pnpm -r format",
    "format:check": "pnpm -r format:check",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "generate:api-client": "pnpm --filter @match/api-client generate",
    "prisma:generate": "pnpm --filter api prisma:generate",
    "prisma:migrate": "pnpm --filter api prisma:migrate",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "lefthook": "^2.1.6",
    "oxfmt": "^0.50.0",
    "oxlint": "^1.65.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/engines",
      "@scarf/scarf",
      "bcrypt",
      "esbuild",
      "lightningcss",
      "lefthook",
      "prisma",
      "unrs-resolver",
      "@weapp-tailwindcss/merge",
      "weapp-tailwindcss"
    ],
    "overrides": {
      "@types/sass": "1.43.1"
    }
  },
  "packageManager": "pnpm@10.18.0",
  "engines": {
    "node": ">=22"
  }
}
