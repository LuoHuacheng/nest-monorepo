{
  "name": "match",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "dev:api": "turbo dev --filter=api",
    "dev:admin": "turbo dev --filter=admin",
    "build": "turbo build",
    "build:api": "turbo build --filter=api",
    "build:admin": "turbo build --filter=admin",
    "lint": "turbo lint",
    "lint:check": "turbo lint:check",
    "format": "turbo format",
    "format:check": "turbo format:check",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "generate:api-client": "turbo run generate --filter=@match/api-client",
    "prisma:generate": "pnpm --filter api prisma:generate",
    "prisma:migrate": "pnpm --filter api prisma:migrate",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "lefthook": "^2.1.6",
    "oxfmt": "^0.50.0",
    "oxlint": "^1.65.0",
    "turbo": "^2.9.14"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/engines",
      "@scarf/scarf",
      "bcrypt",
      "esbuild",
      "lightningcss",
      "lefthook",
      "prisma",
      "unrs-resolver",
      "@weapp-tailwindcss/merge",
      "weapp-tailwindcss"
    ],
    "overrides": {
      "@types/sass": "1.43.1"
    }
  },
  "packageManager": "pnpm@10.18.0",
  "engines": {
    "node": ">=22"
  }
}
